# Local development (macOS). Kopieer naar .env — nooit committen.
APP_NAME="Intake Engine"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Amsterdam
APP_URL=http://localhost:8000
APP_LOCALE=nl
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=intake_engine
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

QUEUE_CONNECTION=database
CACHE_STORE=database

# Foto's: private local disk (storage/app/private). Later S3: MEDIA_DISK=s3 + AWS_*.
# Niet "public" gebruiken voor intake-foto's — zie docs/uploads.md en ADR-0003.
FILESYSTEM_DISK=local
MEDIA_DISK=local

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Klantlink-mail (BL-004). Bij MAIL_MAILER=log worden klantlink-mails overgeslagen
# (geen access-tokens in logs, ADR-0002). Lokaal: mailpit/smtp of array in tests.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AI-provider (nog niet in gebruik — placeholder voor latere features)
# AI_PROVIDER: null (uit) | fake | heuristic (lokaal) | openai (extern, vereist key + DPIA)
AI_PROVIDER=null
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=20
# Options: null (uit), fake (tests), heuristic (lokale samenvatting zonder externe API)

# Klantlink geldigheid in dagen
INTAKE_TOKEN_TTL_DAYS=60

# Herinnering stilliggende intake (BL-015): dagen na aanmaken, max één mail.
INTAKE_REMINDER_DAYS=3

# Hard purge na soft delete (BL-009), in dagen.
INTAKE_SOFT_DELETE_RETENTION_DAYS=30

# Publieke demo ("Start demo" op homepage). Zet aan op staging; productie bewust uit.
DEMO_ENABLED=false
DEMO_TTL_HOURS=12
DEMO_USER_EMAIL=demo@intake-engine.invalid
DEMO_THROTTLE_PER_HOUR=5

# Foto-uploads (app-limiet; PHP upload_max_filesize moet >= dit zijn)
INTAKE_UPLOAD_MAX_KB=5120
INTAKE_UPLOAD_MAX_FILES=5

VITE_APP_NAME="${APP_NAME}"
