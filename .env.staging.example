# Staging (cPanel). Zet als .env in shared/ op de server — nooit committen.
APP_NAME="Intake Engine (staging)"
APP_ENV=staging
APP_KEY=            # genereer op server: php artisan key:generate
APP_DEBUG=false
APP_TIMEZONE=Europe/Amsterdam
APP_URL=https://staging.intake-engine.nl
APP_LOCALE=nl

LOG_CHANNEL=daily
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=            # cPanel MySQL database
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_COOKIE=intake_engine_staging_session
QUEUE_CONNECTION=database
CACHE_STORE=database

FILESYSTEM_DISK=local
MEDIA_DISK=local

# BL-004: zet smtp + credentials zodat klantlink-mails echt aankomen.
# Bij MAIL_MAILER=log slaat de app klantlink-mails over (geen tokens in logs, ADR-0002).
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="staging@intake-engine.nl"
MAIL_FROM_NAME="${APP_NAME}"

AI_PROVIDER=null
AI_API_KEY=
AI_TIMEOUT_SECONDS=20
# Vereist voor de foto-afleiding in template v6. Een AI_API_KEY alleen is niet genoeg:
# zonder deze vlag slaat DerivePhotoAnswers over en blijft elke afleidbare vraag staan.
AI_PHOTO_INFERENCE_ENABLED=false
AI_PHOTO_INFERENCE_MAX_IMAGES=2

PDOK_ENABLED=true
PDOK_SEARCH_BASE_URL=https://api.pdok.nl/bzk/locatieserver/search/v3_1
PDOK_BAG_BASE_URL=https://api.pdok.nl/kadaster/bag/ogc/v2
PDOK_TIMEOUT_SECONDS=5
PDOK_AERIAL_ENABLED=true
PDOK_AERIAL_WMS_URL=https://service.pdok.nl/hwh/luchtfotorgb/wms/v1_0
PDOK_AERIAL_LAYER=Actueel_orthoHR
PDOK_AERIAL_TIMEOUT_SECONDS=4
PDOK_AERIAL_WIDTH=900
PDOK_AERIAL_HEIGHT=600
PDOK_AERIAL_GROUND_WIDTH_METERS=180

# Kadaster BAG API Individuele Bevragingen. Gezaghebbende, near-realtime BAG-kenmerken
# met exacte bevraging op postcode + huisnummer. Zonder key of bij storing valt de
# verrijking terug op de open PDOK-route, dus dit is optioneel.
# LET OP: de key hoort in de shared .env per omgeving, nooit in de repo.
BAG_API_ENABLED=false
BAG_API_BASE_URL=https://api.bag.kadaster.nl/lvbag/individuelebevragingen/v2
BAG_API_KEY=
BAG_API_TIMEOUT_SECONDS=5

# 3DBAG (TU Delft) — pandgeometrie: dakvorm en gevelhoogte bij het BAG-pand.
# Open data onder CC BY 4.0, dus opslaan en tonen in het dossier mag mits de bron
# vermeld blijft. Levert context voor de installateur, geen antwoorden.
THREEDBAG_ENABLED=true
THREEDBAG_BASE_URL=https://api.3dbag.nl
THREEDBAG_TIMEOUT_SECONDS=5

# Herinnering stilliggende intake (BL-015). Vereist werkende SMTP (niet log).
INTAKE_REMINDER_DAYS=3
INTAKE_FOLLOW_UP_MAX_ROUNDS=3
INTAKE_FOLLOW_UP_MAX_ITEMS=5
INTAKE_FOLLOW_UP_MAX_PHOTOS=5
INTAKE_FOLLOW_UP_MAX_DOCUMENTS=3

# Hard purge na soft delete (BL-009).
INTAKE_SOFT_DELETE_RETENTION_DAYS=30

# Publieke demo ("Start demo" op homepage). Standaard aan; false = knop/route uit.
DEMO_ENABLED=true
DEMO_TTL_HOURS=12
DEMO_USER_EMAIL=demo@intake-engine.invalid
DEMO_THROTTLE_PER_HOUR=5
