# Staging (cPanel). Zet als .env in shared/ op de server — nooit committen.
APP_NAME="Intake Engine (staging)"
APP_ENV=staging
APP_KEY=            # genereer op server: php artisan key:generate
APP_DEBUG=false
APP_TIMEZONE=Europe/Amsterdam
APP_URL=https://staging.example.com
APP_LOCALE=nl

LOG_CHANNEL=daily
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=            # cPanel MySQL database
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

FILESYSTEM_DISK=local
MEDIA_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="staging@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AI_PROVIDER=null
AI_API_KEY=
AI_TIMEOUT_SECONDS=20

# Publieke demo ("Start demo" op homepage). Op staging aanbevolen: true.
DEMO_ENABLED=true
DEMO_TTL_HOURS=12
DEMO_USER_EMAIL=demo@intake-engine.invalid
DEMO_THROTTLE_PER_HOUR=5
