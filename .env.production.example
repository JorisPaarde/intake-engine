# Production (cPanel). Zet als .env in shared/ op de server — nooit committen.
APP_NAME="Intake Engine"
APP_ENV=production
APP_KEY=            # genereer op server: php artisan key:generate
APP_DEBUG=false
APP_TIMEZONE=Europe/Amsterdam
APP_URL=https://example.com
APP_LOCALE=nl

LOG_CHANNEL=daily
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

FILESYSTEM_DISK=local
MEDIA_DISK=public      # later: s3, zonder codewijzigingen

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AI_PROVIDER=
AI_API_KEY=
